# Pinterest Developer app credentials.
# Register a redirect URI matching this value in the Pinterest app settings.
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:8787/oauth/pinterest/callback
PINTEREST_SCOPES=boards:read,pins:read

# Optional: use an existing access token instead of the local OAuth token file.
PINTEREST_ACCESS_TOKEN=

# Optional analysis settings.
OPENAI_API_KEY=
OPENAI_MODEL=

# Brand output settings.
BRAND_NAME=COLAPIS
BRAND_TAGLINE=personal brand project
